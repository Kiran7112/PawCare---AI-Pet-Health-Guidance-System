# Copy to .env and fill in real values. NEVER commit the real .env.
# At least one OpenAI key is required for the LLM agents.
OPENAI_API_KEY=sk-...
# Optional fallback keys (rotated automatically on quota/auth errors):
# OPENAI_API_KEY_1=
# OPENAI_API_KEY_2=

# Optional integrations (not required to run the assessment):
GEMINI_KEY=
TAVILY_KEY=
LANGSMITH_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# API server: comma-separated allowed CORS origins for the React frontend.
PAWCARE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
